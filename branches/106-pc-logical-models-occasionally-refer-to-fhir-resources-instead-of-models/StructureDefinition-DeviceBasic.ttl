           fhir:v "string"^^xsd:anyURI ;
           fhir:l fhir:string
         ]
       ] )
     ] [
       fhir:id [ fhir:v "DeviceBasic.name.type" ] ;
       fhir:path [ fhir:v "DeviceBasic.name.type" ] ;
       fhir:short [ fhir:v "The type of name" ] ;
       fhir:definition [ fhir:v "The type of name" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:base [
